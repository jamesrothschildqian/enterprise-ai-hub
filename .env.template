# ============================================================
# Enterprise AI Hub · 环境配置模板
# ============================================================
# 使用方式:
#   1. 复制本文件为 .env
#   2. 根据需要填写 AI 供应商的 API Key
#   3. 启动后端: python backend/main.py
# ============================================================

# ─── 应用基础配置 ──────────────────────────────────────────
# Debug 模式 (生产环境请设为 false)
DEBUG=True

# ─── AI 供应商切换 ────────────────────────────────────────
# 可选值: "deepseek" | "openai" | "mock"
#   deepseek - 使用 DeepSeek 大模型（性价比高）
#   openai   - 使用 OpenAI 大模型（如 GPT-4o-mini）
#   mock     - 模拟模式，无需 API Key，返回预置回复
# ※ 现场 PoC 演示时建议使用 "mock"，开箱即用
# ※ 正式演示或开发调试时，替换下方 API Key 后切换为 "deepseek" 或 "openai"
AI_PROVIDER=mock

# ─── DeepSeek 配置（当 AI_PROVIDER=deepseek 时生效） ──────
# 申请地址: https://platform.deepseek.com/api_keys
# ※ 将 your_deepseek_api_key_here 替换为你的真实 API Key
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ─── OpenAI 配置（当 AI_PROVIDER=openai 时生效） ──────────
# 申请地址: https://platform.openai.com/api-keys
# ※ 将 your_openai_api_key_here 替换为你的真实 API Key
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ─── 默认行业切换 ─────────────────────────────────────────
# 首次启动时选中的行业
# 可选值: international_trade | smart_manufacturing | finance |
#         shipping_logistics | real_estate | hr
CURRENT_INDUSTRY=international_trade
